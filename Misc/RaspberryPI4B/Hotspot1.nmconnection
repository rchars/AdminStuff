id=Hotspot1
uuid=cccccccc-cccc-cccc-cccc-cccccccccccc
type=wifi
autoconnect-priority=997
interface-name=wlan1
lldp=0
llmnr=0
mdns=0
timestamp=0000000000

[wifi]
ap-isolation=1
cloned-mac-address=permanent
mac-address-randomization=1
mode=ap
ssid=Hotspot1

[wifi-security]
group=ccmp;
key-mgmt=wpa-psk
pairwise=ccmp;
proto=rsn;
psk=SECRET_PASSWORD_1

[ipv4]
address1=10.42.1.1/24
dhcp-ipv6-only-preferred=0
may-fail=false
method=manual

[ipv6]
addr-gen-mode=default
method=disabled

[proxy]
